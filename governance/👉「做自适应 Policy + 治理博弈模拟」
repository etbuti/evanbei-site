{
  "version": "1.0",

  "base_policy": "default",

  "adaptive": {
    "enabled": true,

    "targets": {
      "false_positive_rate": 0.05,
      "anomaly_detection_rate": 0.8
    },

    "adjustments": {
      "anomaly_penalty": {
        "min": 5,
        "max": 20,
        "step": 1
      },
      "approve_threshold": {
        "min": 2,
        "max": 5,
        "step": 0.5
      }
    }
  }
}
